{
  "name": "webcoin-labs-2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm exec prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:ci": "next lint --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "typecheck": "tsc --noEmit",
    "audit:prod": "pnpm audit --prod",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:apply:founder-hardening": "prisma db execute --schema prisma/schema.prisma --file prisma/migrations/20260321133000_founder_os_expansion_hardening/migration.sql",
    "db:backfill:canonical": "ts-node --transpile-only scripts/backfill-canonical-graph.ts",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:studio": "prisma studio",
    "check:prisma-touchpoints": "ts-node --transpile-only scripts/check-prisma-touchpoints.ts",
    "certify:integrations": "ts-node --transpile-only scripts/certify-integrations.ts",
    "check:ops-readiness": "ts-node --transpile-only scripts/ops-readiness-check.ts",
    "bootstrap:secrets": "ts-node --transpile-only scripts/bootstrap-secrets.ts"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@google/generative-ai": "^0.24.1",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "next": "15.5.14",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.4",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.14",
    "postcss": "^8.5.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
