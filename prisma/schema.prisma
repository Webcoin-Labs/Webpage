// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUILDER
  FOUNDER
  INVESTOR
  ADMIN
}

enum ProjectStage {
  IDEA
  MVP
  LIVE
}

enum ApplicationType {
  BUILDER_PROGRAM
  FOUNDER_SUPPORT
  PARTNER
  DEMO_DAY_PITCH
}

enum ApplicationStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
}

enum PartnerCategory {
  VC
  CEX
  LAUNCHPAD
  GUILD
  MEDIA
  PORTFOLIO
}

enum PartnerStatus {
  LEGACY
  CURRENT
}

enum IntroType {
  KOL
  VC
}

enum RewardStatus {
  PENDING
  CLAIMED
}

enum PitchDeckUploadStatus {
  RECEIVED
  STORED
  UPLOADED
  FAILED
}

enum PitchDeckProcessingStatus {
  QUEUED
  EXTRACTING
  ANALYZING
  COMPLETED
  FAILED
}

enum AIReportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum DeckType {
  web3
  web2
  unclear
}

enum JobRoleType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
  COFOUNDER
}

enum JobLocationType {
  REMOTE
  HYBRID
  ONSITE
}

enum JobPostStatus {
  OPEN
  CLOSED
  DRAFT
}

enum JobApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

enum HiringInterestStatus {
  NEW
  REVIEWING
  CONTACTED
  ARCHIVED
}

enum UploadAssetType {
  AVATAR
  COMPANY_LOGO
  PITCH_DECK
  OTHER
}

enum UploadModerationStatus {
  ACTIVE
  FLAGGED
  QUARANTINED
  REMOVED
  FAILED
  REPROCESSING
}

enum UploadModerationAction {
  CREATED
  FLAGGED
  QUARANTINED
  RESTORED
  REMOVED
  REPROCESSING_STARTED
  REPROCESSING_SUCCEEDED
  REPROCESSING_FAILED
  NOTE_UPDATED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EventType {
  OFFICE_HOURS
  WORKSHOP
  FOUNDER_TALK
  DEMO_DAY
  COMMUNITY_MEETUP
  AMA
  PARTNER_SESSION
}

enum EventTrack {
  STABLECOINS
  FINTECH
  INFRA
  GTM_DISTRIBUTION
  SECURITY
  LEGAL_COMPLIANCE
}

enum EventFormat {
  ONLINE
  IN_PERSON
  HYBRID
}

enum MeetingProvider {
  CALENDLY
  GOOGLE_MEET
  ZOOM
  OTHER
}

enum EventVisibility {
  PUBLIC
  MEMBERS
  INVITE_ONLY
}

enum RsvpStatus {
  GOING
  INTERESTED
  WAITLISTED
  CANCELED
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  imageStorageKey    String?
  imageMimeType      String?
  imageSize          Int?
  imageWidth         Int?
  imageHeight        Int?
  imageOriginalName  String?
  username           String?   @unique  // unique handle for login (e.g. @johndoe)
  password           String?   @db.Text // bcrypt hash; null for OAuth-only users
  role               Role      @default(BUILDER)
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  builderProfile  BuilderProfile?
  founderProfile  FounderProfile?
  investorProfile InvestorProfile?
  projects        Project[]
  applications    Application[]
  introRequests   IntroRequest[]  @relation("IntroFounder")
  introTargets    IntroRequest[]  @relation("IntroTargetUser")
  rewards         Reward[]
  eventRsvps      EventRsvp[]
  eventReminders  EventReminder[]
  pitchDecks      PitchDeck[]
  jobPosts        JobPost[]
  jobApplications JobApplication[]
  hiringInterestsReceived HiringInterest[] @relation("FounderHiringInterests")
  hiringInterestsSent     HiringInterest[] @relation("BuilderHiringInterests")
  ownedUploadAssets       UploadAsset[]         @relation("UploadAssetOwner")
  moderatedUploadAssets   UploadAsset[]         @relation("UploadAssetModerator")
  avatarUploadAsset       UploadAsset?          @relation("UserAvatarAsset")
  uploadModerationLogs    UploadModerationLog[] @relation("UploadModerationActor")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BuilderProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  handle                String?  @unique
  title                 String?
  headline              String?
  affiliation           String?
  independent           Boolean  @default(false)
  openToWork            Boolean  @default(true)
  bio                   String?  @db.Text
  skills                String[]
  preferredChains       String[] @default([])
  openTo                String[] @default([])
  location              String?
  timezone              String?
  github                String?
  linkedin              String?
  twitter               String?
  website               String?
  portfolioUrl          String?
  experience            String?
  interests             String[]
  publicVisible         Boolean  @default(true)
  verifiedByWebcoinLabs Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FounderProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  companyLogoUrl        String?
  companyLogoStorageKey String?
  companyLogoMimeType   String?
  companyLogoSize       Int?
  companyLogoWidth      Int?
  companyLogoHeight     Int?
  companyLogoOriginalName String?
  companyName           String?
  companyDescription    String?  @db.Text
  roleTitle             String?
  bio                   String?  @db.Text
  location              String?
  timezone              String?
  isHiring              Boolean  @default(false)
  projectStage          ProjectStage?
  chainFocus            String?
  currentNeeds          String[] @default([])
  website               String?
  pitchDeckUrl          String?
  linkedin              String?
  telegram              String?
  twitter               String?
  verifiedByWebcoinLabs Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitchDecks PitchDeck[]
  hiringInterests HiringInterest[]
  logoUploadAsset UploadAsset? @relation("FounderLogoAsset")
}

model InvestorProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firmName  String?
  roleTitle String?
  focus     String?
  location  String?
  website   String?
  linkedin  String?
  twitter   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id                    String       @id @default(cuid())
  ownerUserId           String
  name                  String
  slug                  String?      @unique
  tagline               String?
  description           String?      @db.Text
  chainFocus            String?
  stage                 ProjectStage @default(IDEA)
  websiteUrl            String?
  githubUrl             String?
  twitterUrl            String?
  publicVisible         Boolean      @default(true)
  verifiedByWebcoinLabs Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceIntros IntroRequest[]
  pitchDecks   PitchDeck[]
  jobPosts     JobPost[]
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  type      ApplicationType
  answers   Json
  status    ApplicationStatus @default(NEW)
  notes     String?           @db.Text
  eventId   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Event {
  id                  String           @id @default(cuid())
  slug                String           @unique
  title               String
  summary             String?          @db.Text
  description         String?          @db.Text
  type                EventType
  track               EventTrack?
  format              EventFormat     @default(ONLINE)
  visibility          EventVisibility @default(PUBLIC)
  startAt             DateTime
  endAt               DateTime
  timezone            String           @default("UTC")
  locationText        String?
  meetingUrl          String?
  meetingProvider     MeetingProvider?
  coverImageUrl       String?
  hostUserId          String?
  partnerId           String?
  capacity            Int?
  isPublished        Boolean          @default(false)
  isFeatured         Boolean          @default(false)
  requiresApplication Boolean         @default(false)
  recordingUrl        String?
  notesUrl            String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  rsvps         EventRsvp[]
  reminders     EventReminder[]
  applications  Application[]
}

model EventRsvp {
  id          String     @id @default(cuid())
  eventId     String
  userId      String
  status      RsvpStatus  @default(GOING)
  checkedInAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventReminder {
  id        String    @id @default(cuid())
  eventId   String
  userId    String
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Partner {
  id        String          @id @default(cuid())
  slug     String?          @unique
  name      String
  logoPath  String?
  category  PartnerCategory
  status    PartnerStatus   @default(LEGACY)
  url       String?
  featured  Boolean         @default(false)
  sortOrder Int             @default(0)
  introRequests IntroRequest[]
}

model IntroRequest {
  id              String    @id @default(cuid())
  founderId       String
  type            IntroType
  requestPayload  Json      // KOL: category, budgetRange, campaignGoal; VC: category, stage, region
  status          String    @default("PENDING") // PENDING, REVIEWING, MATCHED, CLOSED
  notes           String?   @db.Text
  sourceProjectId String?
  targetUserId    String?
  targetPartnerId String?
  contextSummary  String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  founder      User     @relation("IntroFounder", fields: [founderId], references: [id], onDelete: Cascade)
  sourceProject Project? @relation(fields: [sourceProjectId], references: [id], onDelete: SetNull)
  targetUser   User?    @relation("IntroTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetPartner Partner? @relation(fields: [targetPartnerId], references: [id], onDelete: SetNull)
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String   @db.Text
  source    String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Reward {
  id             String       @id @default(cuid())
  userId         String?
  externalHandle String?      // optional Telegram handle for lookup before user exists
  label          String       // e.g. "Monsterra token"
  amountText     String       // e.g. "100"
  status         RewardStatus @default(PENDING)
  claimedAt      DateTime?
  createdAt      DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PitchDeck {
  id               String                @id @default(cuid())
  userId           String
  founderProfileId String?
  projectId        String?
  fileUrl          String
  storageKey       String?
  originalFileName String
  fileType         String
  fileSize         Int
  uploadStatus     PitchDeckUploadStatus @default(RECEIVED)
  processingStatus PitchDeckProcessingStatus @default(QUEUED)
  analysisProvider String?
  extractedText    String?               @db.Text
  extractionError  String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  founderProfile FounderProfile? @relation(fields: [founderProfileId], references: [id], onDelete: SetNull)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reports       AIReport[]
  uploadAsset   UploadAsset?   @relation("PitchDeckUploadAsset")
}

model AIReport {
  id                        String         @id @default(cuid())
  pitchDeckId               String
  status                    AIReportStatus @default(QUEUED)
  modelName                 String?
  deckType                  DeckType?      @default(unclear)
  clarityScore              Int?
  completenessScore         Int?
  investorReadinessScore    Int?
  marketPositioningSummary  String?        @db.Text
  productThesis             String?        @db.Text
  businessModelSummary      String?        @db.Text
  problemSummary            String?        @db.Text
  solutionSummary           String?        @db.Text
  targetCustomerSummary     String?        @db.Text
  tractionSummary           String?        @db.Text
  tokenModelSummary         String?        @db.Text
  goToMarketSummary         String?        @db.Text
  fundingReadinessNotes     String?        @db.Text
  strengths                 Json?
  gtmGaps                   Json?
  risks                     Json?
  nextSteps                 Json?
  missingInformation        Json?
  confidenceNotes           String?        @db.Text
  rawJson                   Json?
  errorMessage              String?        @db.Text
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  pitchDeck PitchDeck @relation(fields: [pitchDeckId], references: [id], onDelete: Cascade)

  @@index([pitchDeckId, createdAt])
}

model UploadAsset {
  id                String                 @id @default(cuid())
  assetType         UploadAssetType
  status            UploadModerationStatus @default(ACTIVE)
  fileUrl           String
  storageKey        String?                @unique
  mimeType          String?
  fileSize          Int?
  width             Int?
  height            Int?
  originalName      String?
  ownerUserId       String?
  userId            String?                @unique
  founderProfileId  String?                @unique
  pitchDeckId       String?                @unique
  relatedEntityType String?
  relatedEntityId   String?
  moderationReason  String?
  moderationNote    String?                @db.Text
  moderatedByUserId String?
  moderatedAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  ownerUser       User?                @relation("UploadAssetOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  moderatedByUser User?                @relation("UploadAssetModerator", fields: [moderatedByUserId], references: [id], onDelete: SetNull)
  user            User?                @relation("UserAvatarAsset", fields: [userId], references: [id], onDelete: SetNull)
  founderProfile  FounderProfile?      @relation("FounderLogoAsset", fields: [founderProfileId], references: [id], onDelete: SetNull)
  pitchDeck       PitchDeck?           @relation("PitchDeckUploadAsset", fields: [pitchDeckId], references: [id], onDelete: SetNull)
  logs            UploadModerationLog[]

  @@index([assetType, status, createdAt])
  @@index([ownerUserId, createdAt])
  @@index([status, updatedAt])
}

model UploadModerationLog {
  id         String                 @id @default(cuid())
  uploadAssetId String
  action     UploadModerationAction
  fromStatus UploadModerationStatus?
  toStatus   UploadModerationStatus?
  reason     String?
  note       String?                @db.Text
  actedByUserId String?
  createdAt  DateTime               @default(now())

  uploadAsset UploadAsset @relation(fields: [uploadAssetId], references: [id], onDelete: Cascade)
  actedByUser User?       @relation("UploadModerationActor", fields: [actedByUserId], references: [id], onDelete: SetNull)

  @@index([uploadAssetId, createdAt])
  @@index([action, createdAt])
}

model HiringInterest {
  id                  String               @id @default(cuid())
  founderId           String
  founderProfileId    String?
  builderUserId       String?
  name                String
  email               String
  skills              String
  portfolioUrl        String?
  message             String?              @db.Text
  source              String?
  founderNameSnapshot String?
  companyNameSnapshot String?
  status              HiringInterestStatus @default(NEW)
  adminNotes          String?              @db.Text
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  founder       User           @relation("FounderHiringInterests", fields: [founderId], references: [id], onDelete: Cascade)
  founderProfile FounderProfile? @relation(fields: [founderProfileId], references: [id], onDelete: SetNull)
  builderUser   User?          @relation("BuilderHiringInterests", fields: [builderUserId], references: [id], onDelete: SetNull)

  @@index([founderId, createdAt])
  @@index([builderUserId, createdAt])
  @@index([status, createdAt])
}

model JobPost {
  id              String          @id @default(cuid())
  title           String
  company         String
  description     String          @db.Text
  roleType        JobRoleType
  locationType    JobLocationType
  chainFocus      String?
  skillsRequired  String[]        @default([])
  compensation    String?
  status          JobPostStatus   @default(OPEN)
  createdByUserId String
  projectId       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  createdBy    User             @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  applications JobApplication[]

  @@index([status, createdAt])
}

model JobApplication {
  id         String               @id @default(cuid())
  jobId      String
  userId     String
  message    String               @db.Text
  resumeUrl  String?
  status     JobApplicationStatus @default(APPLIED)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  job  JobPost @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId, createdAt])
}
