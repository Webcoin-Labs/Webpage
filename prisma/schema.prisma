model TokenomicsAllocationRow {
  id                   String   @id @default(cuid())
  scenarioId           String
  label                String
  percentage           Decimal? @db.Decimal(7, 4)
  tokenAmount          Decimal? @db.Decimal(38, 10)
  cliffMonths          Int?
  vestingMonths        Int?
  unlockCadence        String?
  notes                String?  @db.Text
  rowOrder             Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  scenario TokenomicsScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId, rowOrder])
}

model TokenomicsUpload {
  id            String               @id @default(cuid())
  modelId       String
  uploadedById  String
  fileName      String?
  fileType      String?
  status        TokenomicsUploadStatus @default(QUEUED)
  errorMessage  String?              @db.Text
  payloadJson   Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  model      TokenomicsModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  uploadedBy User           @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([modelId, createdAt])
  @@index([status, updatedAt])
}

model ProfileLink {
  id           String   @id @default(cuid())
  fromUserId   String
  toUserId     String
  label        String?
  createdAt    DateTime @default(now())

  fromUser User @relation("ProfileLinkFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ProfileLinkTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, createdAt])
}

model MutationAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
}

model AIReport {
  id                        String         @id @default(cuid())
  pitchDeckId               String
  status                    AIReportStatus @default(QUEUED)
  modelName                 String?
  deckType                  DeckType?      @default(unclear)
  clarityScore              Int?
  completenessScore         Int?
  investorReadinessScore    Int?
  marketPositioningSummary  String?        @db.Text
  productThesis             String?        @db.Text
  businessModelSummary      String?        @db.Text
  problemSummary            String?        @db.Text
  solutionSummary           String?        @db.Text
  targetCustomerSummary     String?        @db.Text
  tractionSummary           String?        @db.Text
  tokenModelSummary         String?        @db.Text
  goToMarketSummary         String?        @db.Text
  fundingReadinessNotes     String?        @db.Text
  strengths                 Json?
  gtmGaps                   Json?
  risks                     Json?
  nextSteps                 Json?
  missingInformation        Json?
  confidenceNotes           String?        @db.Text
  rawJson                   Json?
  errorMessage              String?        @db.Text
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  pitchDeck PitchDeck @relation(fields: [pitchDeckId], references: [id], onDelete: Cascade)
  sections  PitchDeckSection[]
  versions  PitchDeckVersion[]

  @@index([pitchDeckId, createdAt])
}

model PitchDeckSection {
  id             String              @id @default(cuid())
  pitchDeckId    String
  reportId       String?
  sectionKey     String
  sectionTitle   String
  sectionOrder   Int
  extractedText  String              @db.Text
  qualityLabel   PitchSectionQuality
  goodPoints     Json?
  unclearPoints  Json?
  missingPoints  Json?
  fixSummary     String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  pitchDeck PitchDeck @relation(fields: [pitchDeckId], references: [id], onDelete: Cascade)
  report    AIReport?  @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([pitchDeckId, sectionOrder])
  @@index([reportId, createdAt])
}

model PitchDeckVersion {
  id          String               @id @default(cuid())
  pitchDeckId String
  userId      String
  reportId    String?
  name        String
  versionType PitchDeckVersionType
  contentJson Json
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  pitchDeck PitchDeck @relation(fields: [pitchDeckId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  report    AIReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([pitchDeckId, createdAt])
  @@index([userId, createdAt])
}

model UploadAsset {
  id                String                 @id @default(cuid())
  assetType         UploadAssetType
  status            UploadModerationStatus @default(ACTIVE)
  fileUrl           String
  storageKey        String?                @unique
  mimeType          String?
  fileSize          Int?
  width             Int?
  height            Int?
  originalName      String?
  ownerUserId       String?
  userId            String?                @unique
  founderProfileId  String?                @unique
  pitchDeckId       String?                @unique
  relatedEntityType String?
  relatedEntityId   String?
  moderationReason  String?
  moderationNote    String?                @db.Text
  moderatedByUserId String?
  moderatedAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  ownerUser       User?                @relation("UploadAssetOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  moderatedByUser User?                @relation("UploadAssetModerator", fields: [moderatedByUserId], references: [id], onDelete: SetNull)
  user            User?                @relation("UserAvatarAsset", fields: [userId], references: [id], onDelete: SetNull)
  founderProfile  FounderProfile?      @relation("FounderLogoAsset", fields: [founderProfileId], references: [id], onDelete: SetNull)
  pitchDeck       PitchDeck?           @relation("PitchDeckUploadAsset", fields: [pitchDeckId], references: [id], onDelete: SetNull)
  logs            UploadModerationLog[]

  @@index([assetType, status, createdAt])
  @@index([ownerUserId, createdAt])
  @@index([status, updatedAt])
}

model UploadModerationLog {
  id         String                 @id @default(cuid())
  uploadAssetId String
  action     UploadModerationAction
  fromStatus UploadModerationStatus?
  toStatus   UploadModerationStatus?
  reason     String?
  note       String?                @db.Text
  actedByUserId String?
  createdAt  DateTime               @default(now())

  uploadAsset UploadAsset @relation(fields: [uploadAssetId], references: [id], onDelete: Cascade)
  actedByUser User?       @relation("UploadModerationActor", fields: [actedByUserId], references: [id], onDelete: SetNull)

  @@index([uploadAssetId, createdAt])
  @@index([action, createdAt])
}

model HiringInterest {
  id                  String               @id @default(cuid())
  founderId           String
  founderProfileId    String?
  builderUserId       String?
  name                String
  email               String
  skills              String
  portfolioUrl        String?
  message             String?              @db.Text
  source              String?
  founderNameSnapshot String?
  companyNameSnapshot String?
  status              HiringInterestStatus @default(NEW)
  adminNotes          String?              @db.Text
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  founder       User           @relation("FounderHiringInterests", fields: [founderId], references: [id], onDelete: Cascade)
  founderProfile FounderProfile? @relation(fields: [founderProfileId], references: [id], onDelete: SetNull)
  builderUser   User?          @relation("BuilderHiringInterests", fields: [builderUserId], references: [id], onDelete: SetNull)

  @@index([founderId, createdAt])
  @@index([builderUserId, createdAt])
  @@index([status, createdAt])
}

model JobPost {
  id              String          @id @default(cuid())
  title           String
  company         String
  description     String          @db.Text
  roleType        JobRoleType
  locationType    JobLocationType
  chainFocus      String?
  skillsRequired  String[]        @default([])
  compensation    String?
  status          JobPostStatus   @default(OPEN)
  createdByUserId String
  projectId       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  createdBy    User             @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  applications JobApplication[]
  adminAssignments AdminAssignment[]

  @@index([status, createdAt])
}

model JobApplication {
  id         String               @id @default(cuid())
  jobId      String
  userId     String
  message    String               @db.Text
  resumeUrl  String?
  status     JobApplicationStatus @default(APPLIED)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  job  JobPost @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId, createdAt])
}

model Startup {
  id           String           @id @default(cuid())
  founderId    String
  slug         String?          @unique
  name         String
  tagline      String?
  description  String?          @db.Text
  stage        StartupStage
  chainFocus   StartupChainFocus
  website      String?
  twitter      String?
  linkedin     String?
  pitchDeckUrl String?
  githubRepo   String?
  problem      String?          @db.Text
  solution     String?          @db.Text
  traction     String?          @db.Text
  revenue      String?
  usersCount   Int?
  isHiring     Boolean          @default(false)
  canonicalVentureId String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  founder               User                   @relation("StartupFounder", fields: [founderId], references: [id], onDelete: Cascade)
  canonicalVenture      Venture?               @relation("StartupCanonicalVenture", fields: [canonicalVentureId], references: [id], onDelete: SetNull)
  githubActivity        StartupGithubActivity?
  investorIntroRequests InvestorIntroRequest[]
  chatThreads           ChatThread[]
  meetings              MeetingRecord[]
  marketInsights        FounderMarketInsight[]
  ratings               StartupRating[]

  @@index([founderId, createdAt])
  @@index([stage, chainFocus, createdAt])
  @@index([canonicalVentureId])
}

model FounderProfileExtended {
  id                 String   @id @default(cuid())
  userId             String   @unique
  whyThisStartup     String?  @db.Text
  problemStatement   String?  @db.Text
  targetUser         String?  @db.Text
  businessModel      String?  @db.Text
  competitors        String?  @db.Text
  differentiation    String?  @db.Text
  longTermVision     String?  @db.Text
  freeTimeActivities String?  @db.Text
  pastExperience     String?  @db.Text
  whyYou             String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StartupRating {
  id         String   @id @default(cuid())
  startupId  String
  reviewerId String
  score      Int
  note       String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
  reviewer User    @relation("StartupRatingReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([startupId, reviewerId])
  @@index([startupId, createdAt])
  @@index([reviewerId, createdAt])
}

model CofounderPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  roleWanted        String
  equityExpectation String?
  timeCommitment    String?
  remotePreference  String?
  skillsNeeded      String[] @default([])
  motivation        String?  @db.Text
  expectations      String?  @db.Text
  workingStyle      String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GithubConnection {
  id            String   @id @default(cuid())
  userId        String   @unique
  username      String
  profileUrl    String?
  accessMode    String   @default("mock")
  connectedAt   DateTime @default(now())
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StartupGithubActivity {
  id                String   @id @default(cuid())
  startupId          String   @unique
  repoUrl            String
  repoName           String
  lastCommitHash     String?
  lastCommitMessage  String?
  lastCommitAt       DateTime?
  commitActivityJson Json?
  contributorsJson   Json?
  techStack          String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id         String    @id @default(cuid())
  userId     String
  badgeType  BadgeType
  verified   Boolean   @default(false)
  sourceNote String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([badgeType, createdAt])
}

model Investor {
  id               String   @id @default(cuid())
  userId           String   @unique
  canonicalInvestorProfileId String? @unique
  fundName         String
  investmentStage  String
  ticketSize       String?
  thesis           String?  @db.Text
  chainsInterested String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalInvestorProfile InvestorProfile? @relation("InvestorCanonicalProfile", fields: [canonicalInvestorProfileId], references: [id], onDelete: SetNull)
  introRequests  InvestorIntroRequest[] @relation("InvestorIntroInvestor")

  @@index([canonicalInvestorProfileId])
}

model InvestorIntroRequest {
  id                String             @id @default(cuid())
  founderId         String
  startupId         String
  investorUserId    String
  status            InvestorIntroStatus @default(PENDING)
  generatedEmail    String?            @db.Text
  founderNote       String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  founder  User     @relation("InvestorIntroFounder", fields: [founderId], references: [id], onDelete: Cascade)
  startup  Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  investor Investor @relation("InvestorIntroInvestor", fields: [investorUserId], references: [userId], onDelete: Cascade)

  @@index([founderId, createdAt])
  @@index([investorUserId, createdAt])
  @@index([startupId, createdAt])
}

model ChatThread {
  id              String          @id @default(cuid())
  startupId       String?
  createdByUserId String
  title           String
  contextType     ChatContextType @default(GENERAL)
  contextLabel    String?
  inviteToken     String          @unique
  isGroup         Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  startup     Startup?          @relation(fields: [startupId], references: [id], onDelete: SetNull)
  creator     User              @relation("ChatThreadCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages    ChatMessage[]

  @@index([createdByUserId, createdAt])
  @@index([startupId, createdAt])
}

model ChatParticipant {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  roleLabel String?
  joinedAt  DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model MeetingLink {
  id         String   @id @default(cuid())
  userId     String   @unique
  calendlyUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeetingRecord {
  id             String   @id @default(cuid())
  startupId      String?
  hostUserId     String
  attendeeUserId String
  title          String
  scheduledAt    DateTime
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  startup  Startup? @relation(fields: [startupId], references: [id], onDelete: SetNull)
  host     User     @relation("MeetingHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  attendee User     @relation("MeetingAttendee", fields: [attendeeUserId], references: [id], onDelete: Cascade)

  @@index([hostUserId, scheduledAt])
  @@index([attendeeUserId, scheduledAt])
}

model MarketSignal {
  id          String   @id @default(cuid())
  createdById String?
  source      String
  signalType  String
  title       String
  summary     String   @db.Text
  signalUrl   String?
  createdAt   DateTime @default(now())

  createdBy User? @relation("MarketSignalAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([source, createdAt])
}

model FounderMarketInsight {
  id                   String   @id @default(cuid())
  founderId            String
  startupId            String?
  founderPainPoints    String   @db.Text
  trendingProblems     String   @db.Text
  generatedBy          String?  @default("GEMINI")
  sourceSignalCount    Int      @default(0)
  createdAt            DateTime @default(now())

  founder User     @relation(fields: [founderId], references: [id], onDelete: Cascade)
  startup Startup? @relation(fields: [startupId], references: [id], onDelete: SetNull)

  @@index([founderId, createdAt])
}

model BuilderProject {
  id                      String   @id @default(cuid())
  builderId               String
  title                   String
  tagline                 String?
  description             String?  @db.Text
  imageUrl                String?
  achievements            String?  @db.Text
  openSourceContributions String?  @db.Text
  githubUrl               String?
  liveUrl                 String?
  techStack               String[] @default([])
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  builder User @relation("BuilderProjects", fields: [builderId], references: [id], onDelete: Cascade)

  @@index([builderId, updatedAt])
}

model Notification {
  id         String   @id @default(cuid())
  title      String
  message    String   @db.Text
  featureUrl String?
  targetRoles Role[]  @default([BUILDER, FOUNDER, INVESTOR, ADMIN])
  createdById String?
  createdAt  DateTime @default(now())

  createdBy User? @relation("NotificationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reads     NotificationRead[]

  @@index([createdAt])
  @@index([createdById, createdAt])
  @@index([createdAt, id])
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@index([userId, notificationId])
}

model InviteOnlyCode {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String?
  isActive    Boolean  @default(true)
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime @default(now())

  createdBy   User?                 @relation("InviteCodeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  memberships InviteOnlyMembership[]

  @@index([isActive, createdAt])
}

model InviteOnlyMembership {
  id       String   @id @default(cuid())
  userId   String   @unique
  codeId   String
  joinedAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  code InviteOnlyCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@index([codeId, joinedAt])
}
