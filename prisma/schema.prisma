  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum FeedPostType {
  STARTUP_LAUNCH
  FUNDRAISING_UPDATE
  HIRING_BUILDER
  PRODUCT_UPDATE
  BUILDER_PROJECT
  OPEN_SOURCE_UPDATE
  BUILDER_AVAILABLE
  INVESTOR_THESIS
  INVESTOR_OPEN_CALL
  PORTFOLIO_UPDATE
  ECOSYSTEM_SIGNAL
  MILESTONE_UPDATE
}

enum FeedPostVisibility {
  PUBLIC
  INTERNAL
  PRIVATE
}

enum ContactMethodType {
  TELEGRAM
  EMAIL
  DISCORD
  X
  LINKEDIN
}

enum ConnectionRequestStatus {
  PENDING
  ACCEPTED
