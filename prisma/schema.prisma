}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EventType {
  OFFICE_HOURS
  WORKSHOP
  FOUNDER_TALK
  DEMO_DAY
  COMMUNITY_MEETUP
  AMA
  PARTNER_SESSION
}

enum EventTrack {
  STABLECOINS
  FINTECH
  INFRA
  GTM_DISTRIBUTION
  SECURITY
  LEGAL_COMPLIANCE
}

enum EventFormat {
  ONLINE
  IN_PERSON
  HYBRID
}

enum MeetingProvider {
  CALENDLY
  GOOGLE_MEET
  ZOOM
  OTHER
}

enum EventVisibility {
  PUBLIC
  MEMBERS
  INVITE_ONLY
}

enum RsvpStatus {
  GOING
  INTERESTED
  WAITLISTED
  CANCELED
}

model User {
  id                 String    @id @default(cuid())
  supabaseAuthId     String?   @unique
  authProvider       String?
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  imageStorageKey    String?
  imageMimeType      String?
  imageSize          Int?
  imageWidth         Int?
  imageHeight        Int?
  imageOriginalName  String?
  username           String?   @unique  // unique handle for login (e.g. @johndoe)
  password           String?   @db.Text // bcrypt hash; null for OAuth-only users
  role               Role      @default(BUILDER)
  bio                String?   @db.Text
  educationBackground String?  @db.Text
  socialLinks        Json?
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  builderProfile  BuilderProfile?
  founderProfile  FounderProfile?
  investorProfile InvestorProfile?
  projects        Project[]
  applications    Application[]
  introRequests   IntroRequest[]  @relation("IntroFounder")
  introTargets    IntroRequest[]  @relation("IntroTargetUser")
  rewards         Reward[]
  eventRsvps      EventRsvp[]
  eventReminders  EventReminder[]
  pitchDecks      PitchDeck[]
  pitchDeckVersions PitchDeckVersion[]
  jobPosts        JobPost[]
  jobApplications JobApplication[]
  hiringInterestsReceived HiringInterest[] @relation("FounderHiringInterests")
  hiringInterestsSent     HiringInterest[] @relation("BuilderHiringInterests")
  ownedUploadAssets       UploadAsset[]         @relation("UploadAssetOwner")
  moderatedUploadAssets   UploadAsset[]         @relation("UploadAssetModerator")
  avatarUploadAsset       UploadAsset?          @relation("UserAvatarAsset")
  uploadModerationLogs    UploadModerationLog[] @relation("UploadModerationActor")
  startups                Startup[]             @relation("StartupFounder")
  founderProfileExtended  FounderProfileExtended?
  cofounderPreferences    CofounderPreferences?
  investor                Investor?
  githubConnection        GithubConnection?
  badges                  UserBadge[]
  investorIntroRequests   InvestorIntroRequest[] @relation("InvestorIntroFounder")
  chatThreadsCreated      ChatThread[]          @relation("ChatThreadCreator")
  chatParticipants        ChatParticipant[]
  chatMessages            ChatMessage[]
  meetingLink             MeetingLink?
  meetingsAsHost          MeetingRecord[]       @relation("MeetingHost")
  meetingsAsAttendee      MeetingRecord[]       @relation("MeetingAttendee")
  marketSignals           MarketSignal[]        @relation("MarketSignalAuthor")
  founderMarketInsights   FounderMarketInsight[]
  startupRatingsGiven     StartupRating[]       @relation("StartupRatingReviewer")
  builderProjects         BuilderProject[]      @relation("BuilderProjects")
  notificationsCreated    Notification[]        @relation("NotificationCreator")
  notificationReads       NotificationRead[]
  inviteCodesCreated      InviteOnlyCode[]      @relation("InviteCodeCreator")
  inviteOnlyMembership    InviteOnlyMembership?
  workspaceMemberships    UserWorkspace[]
  walletConnections       WalletConnection[]
  integrationConnections  IntegrationConnection[]
  publicProfileSettings   PublicProfileSettings?
  premiumSubscription     PremiumSubscription?
  founderInvestorQuota    FounderInvestorRequestQuota?
  resumeDocuments         ResumeDocument[]
  coverLetterDrafts       CoverLetterDraft[]
  ownedVentures           Venture[]             @relation("VentureOwner")
  investorApplicationsSent InvestorApplication[] @relation("InvestorApplicationFounder")
  investorApplicationsReceived InvestorApplication[] @relation("InvestorApplicationInvestor")
  investorCompanyMemberships InvestorCompanyMember[]
  miniApps                MiniAppMetadata[]     @relation("MiniAppOwner")
  emailThreads            EmailThread[]
  workspaceMeetingsHost   WorkspaceMeeting[]    @relation("WorkspaceMeetingHost")
  workspaceMeetingsGuest  WorkspaceMeeting[]    @relation("WorkspaceMeetingGuest")
  openClawConnection      OpenClawConnection?
  telegramMessagesSent    TelegramMessage[]      @relation("TelegramMessageSender")
  telegramMessagesReceived TelegramMessage[]     @relation("TelegramMessageRecipient")
  tokenomicsModelsCreated TokenomicsModel[]      @relation("TokenomicsModelCreator")
  tokenomicsUploads       TokenomicsUpload[]
  investorCommitments     InvestorCommitment[]   @relation("InvestorCommitmentInvestor")
  raiseRoundsOwned        RaiseRound[]           @relation("RaiseRoundFounder")
  profileLinksFrom        ProfileLink[]          @relation("ProfileLinkFrom")
  profileLinksTo          ProfileLink[]          @relation("ProfileLinkTo")
  tokenomicsScenarioRevisions TokenomicsScenarioRevision[] @relation("TokenomicsScenarioRevisionAuthor")
  scoreSnapshotsSubject   ScoreSnapshot[]        @relation("ScoreSnapshotSubject")
  scoreSnapshotsOverridden ScoreSnapshot[]       @relation("ScoreSnapshotOverriddenBy")
  diligenceMemosAuthored  DiligenceMemo[]        @relation("DiligenceMemoAuthor")
  adminAssignmentsCreated AdminAssignment[]      @relation("AdminAssignmentCreatedBy")
  adminAssignmentsOwned   AdminAssignment[]      @relation("AdminAssignmentAssignee")
  adminAssignmentsFounder AdminAssignment[]      @relation("AdminAssignmentFounder")
  adminAssignmentsBuilder AdminAssignment[]      @relation("AdminAssignmentBuilder")
  adminAssignmentsInvestor AdminAssignment[]     @relation("AdminAssignmentInvestor")
  visibilityRulesAllowed  VisibilityRule[]       @relation("VisibilityRuleAllowedUser")
  visibilityRulesCreated  VisibilityRule[]       @relation("VisibilityRuleCreatedBy")
  mutationAuditLogs       MutationAuditLog[]
  advisorProfile          AdvisorProfile?
  advisorAccessGrant      AdvisorAccessGrant?
  projectAdvisorInvitesCreated ProjectAdvisorInvite[] @relation("ProjectAdvisorInviteCreator")
  projectAdvisorInvitesRedeemed ProjectAdvisorInvite[] @relation("ProjectAdvisorInviteRedeemedBy")
  projectAdvisorConnectionsCreated ProjectAdvisorConnection[] @relation("ProjectAdvisorConnectionCreator")
  projectAdvisorAccessGranted AdvisorAccessGrant[] @relation("AdvisorAccessGrantedByAdmin")
  feedPosts             FeedPost[]
  profileViewsFrom      ProfileView[] @relation("ProfileViewViewer")
  profileViewsTo        ProfileView[] @relation("ProfileViewViewed")
  profileContactMethods ProfileContactMethod[]
  connectionRequestsSent ConnectionRequest[] @relation("ConnectionRequestSender")
  connectionRequestsReceived ConnectionRequest[] @relation("ConnectionRequestRecipient")
}

model ConnectionRequest {
  id          String                  @id @default(cuid())
  fromUserId  String
  toUserId    String
  message     String?                 @db.Text
  source      String?
  status      ConnectionRequestStatus @default(PENDING)
  respondedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  fromUser User @relation("ConnectionRequestSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ConnectionRequestRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status, createdAt])
  @@index([fromUserId, status, createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BuilderProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  handle                String?  @unique
  title                 String?
  headline              String?
  affiliation           String?
  independent           Boolean  @default(false)
  openToWork            Boolean  @default(true)
  bio                   String?  @db.Text
  skills                String[]
  preferredChains       String[] @default([])
  openTo                String[] @default([])
  location              String?
  timezone              String?
  github                String?
  linkedin              String?
  twitter               String?
  website               String?
  portfolioUrl          String?
  experience            String?
  interests             String[]
  achievements          String?  @db.Text
  openSourceContributions String? @db.Text
  educationBackground   String?  @db.Text
  stack                 String[] @default([])
  chainExpertise        String[] @default([])
  availability          String?
  lookingForRoles       String[] @default([])
  coverLetterProfile    String? @db.Text
  resumeUrl             String?
  publicVisible         Boolean  @default(true)
  verifiedByWebcoinLabs Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FounderProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  companyLogoUrl        String?
  companyLogoStorageKey String?
  companyLogoMimeType   String?
  companyLogoSize       Int?
  companyLogoWidth      Int?
  companyLogoHeight     Int?
  companyLogoOriginalName String?
  companyName           String?
  companyDescription    String?  @db.Text
  roleTitle             String?
  bio                   String?  @db.Text
  location              String?
  timezone              String?
  isHiring              Boolean  @default(false)
  projectStage          ProjectStage?
  chainFocus            String?
  currentNeeds          String[] @default([])
  educationBackground   String?  @db.Text
  founderDescription    String?  @db.Text
  lookingFor            String[] @default([])
  farcasterMiniAppUrl   String?
  baseMiniAppUrl        String?
  website               String?
  pitchDeckUrl          String?
  linkedin              String?
  telegram              String?
  twitter               String?
  publicVisible         Boolean  @default(true)
  verifiedByWebcoinLabs Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitchDecks PitchDeck[]
  hiringInterests HiringInterest[]
  logoUploadAsset UploadAsset? @relation("FounderLogoAsset")

  @@index([isHiring, updatedAt])
}

model InvestorProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  investorType InvestorType?
  headline  String?
  firmName  String?
  companyId String?
  roleTitle String?
  focus     String?
  location  String?
  website   String?
  linkedin  String?
  twitter   String?
  ticketSize String?
  stageFocus String[] @default([])
  chainFocus String[] @default([])
  sectorFocus String[] @default([])
  geography  String?
  checkSizeMin Int?
  checkSizeMax Int?
  lookingFor String?
  investmentThesis String? @db.Text
  isPublic   Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  company InvestorCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  legacyInvestorRecord Investor? @relation("InvestorCanonicalProfile")
}

model Project {
  id                    String       @id @default(cuid())
  ownerUserId           String
  name                  String
  slug                  String?      @unique
  tagline               String?
  description           String?      @db.Text
  chainFocus            String?
  stage                 ProjectStage @default(IDEA)
  websiteUrl            String?
  githubUrl             String?
  twitterUrl            String?
  canonicalVentureId    String?
  publicVisible         Boolean      @default(true)
  verifiedByWebcoinLabs Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  canonicalVenture Venture? @relation("ProjectCanonicalVenture", fields: [canonicalVentureId], references: [id], onDelete: SetNull)
  sourceIntros IntroRequest[]
  pitchDecks   PitchDeck[]
  jobPosts     JobPost[]
  advisorInvites ProjectAdvisorInvite[]
  advisorConnections ProjectAdvisorConnection[]
  feedPosts FeedPost[] @relation("FeedPostProject")

  @@index([ownerUserId, updatedAt])
  @@index([canonicalVentureId])
}

model AdvisorProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  headline              String?
  bio                   String?  @db.Text
  expertise             String[] @default([])
  hourlyRateUsd         Int?
  companyName           String?
  website               String?
  linkedin              String?
  telegram              String?
  publicVisible         Boolean  @default(true)
  verifiedByWebcoinLabs Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectConnections ProjectAdvisorConnection[]

  @@index([publicVisible, updatedAt])
}

model ProjectAdvisorInvite {
  id             String   @id @default(cuid())
  token          String   @unique
  projectId      String
  createdByAdminId String
  usedByUserId   String?
  isActive       Boolean  @default(true)
  maxRedemptions Int      @default(1)
  redeemedCount  Int      @default(0)
  expiresAt      DateTime?
  usedAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByAdmin User     @relation("ProjectAdvisorInviteCreator", fields: [createdByAdminId], references: [id], onDelete: Cascade)
  usedByUser     User?    @relation("ProjectAdvisorInviteRedeemedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)
  grants         AdvisorAccessGrant[]
  projectAdvisorConnections ProjectAdvisorConnection[]

  @@index([projectId, createdAt])
  @@index([isActive, expiresAt])
}

model AdvisorAccessGrant {
  id                String   @id @default(cuid())
  userId            String   @unique
  grantedByAdminId  String
  sourceInviteId    String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedByAdmin User @relation("AdvisorAccessGrantedByAdmin", fields: [grantedByAdminId], references: [id], onDelete: Cascade)
  sourceInvite ProjectAdvisorInvite? @relation(fields: [sourceInviteId], references: [id], onDelete: SetNull)
}

model ProjectAdvisorConnection {
  id               String   @id @default(cuid())
  projectId        String
  advisorProfileId String
  connectedByUserId String?
  sourceInviteId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  advisorProfile AdvisorProfile @relation(fields: [advisorProfileId], references: [id], onDelete: Cascade)
  connectedByUser User? @relation("ProjectAdvisorConnectionCreator", fields: [connectedByUserId], references: [id], onDelete: SetNull)
  sourceInvite ProjectAdvisorInvite? @relation(fields: [sourceInviteId], references: [id], onDelete: SetNull)

  @@unique([projectId, advisorProfileId])
  @@index([advisorProfileId, createdAt])
  @@index([projectId, createdAt])
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  type      ApplicationType
  answers   Json
  status    ApplicationStatus @default(NEW)
  notes     String?           @db.Text
  eventId   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model Event {
  id                  String           @id @default(cuid())
  slug                String           @unique
  title               String
  summary             String?          @db.Text
  description         String?          @db.Text
  type                EventType
  track               EventTrack?
  format              EventFormat     @default(ONLINE)
  visibility          EventVisibility @default(PUBLIC)
  startAt             DateTime
  endAt               DateTime
  timezone            String           @default("UTC")
  locationText        String?
  meetingUrl          String?
  meetingProvider     MeetingProvider?
  coverImageUrl       String?
  hostUserId          String?
  partnerId           String?
  capacity            Int?
  isPublished        Boolean          @default(false)
  isFeatured         Boolean          @default(false)
  requiresApplication Boolean         @default(false)
  recordingUrl        String?
  notesUrl            String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  rsvps         EventRsvp[]
  reminders     EventReminder[]
  applications  Application[]
}

model EventRsvp {
  id          String     @id @default(cuid())
  eventId     String
  userId      String
  status      RsvpStatus  @default(GOING)
  checkedInAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventReminder {
  id        String    @id @default(cuid())
  eventId   String
  userId    String
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Partner {
  id        String          @id @default(cuid())
  slug     String?          @unique
  name      String
  logoPath  String?
  category  PartnerCategory
  status    PartnerStatus   @default(LEGACY)
  url       String?
  featured  Boolean         @default(false)
  sortOrder Int             @default(0)
  introRequests IntroRequest[]
}

model IntroRequest {
  id              String    @id @default(cuid())
  founderId       String
  type            IntroType
  requestPayload  Json      // KOL: category, budgetRange, campaignGoal; VC: category, stage, region
  status          String    @default("PENDING") // PENDING, REVIEWING, MATCHED, CLOSED
  notes           String?   @db.Text
  sourceProjectId String?
  targetUserId    String?
  targetPartnerId String?
  contextSummary  String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  founder      User     @relation("IntroFounder", fields: [founderId], references: [id], onDelete: Cascade)
  sourceProject Project? @relation(fields: [sourceProjectId], references: [id], onDelete: SetNull)
