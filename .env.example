# Environment Variables for Webcoin Labs 2.0

# ============================================
# DATABASE (Neon Postgres)
# ============================================
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/webcoinlabs?sslmode=require"

# ============================================
# NEXTAUTH
# ============================================
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# PASSWORD RESET DELIVERY (PRODUCTION REQUIRED)
# ============================================
# Option 1 (recommended): Resend
RESEND_API_KEY=""
PASSWORD_RESET_FROM_EMAIL="Webcoin Labs <no-reply@webcoinlabs.com>"
# Option 2: webhook to your transactional email service
PASSWORD_RESET_WEBHOOK_URL=""
PASSWORD_RESET_WEBHOOK_TOKEN=""

# ============================================
# GOOGLE OAUTH
# ============================================
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# GITHUB OAUTH
# ============================================
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ============================================
# AI PITCH ANALYSIS
# ============================================
# Gemini API key used for pitch deck report generation.
GEMINI_API_KEY="your-gemini-api-key"
# Optional model override.
GEMINI_MODEL="gemini-1.5-pro"
# Use "async" to queue/defer heavy analysis to internal job drain.
PITCH_ANALYSIS_QUEUE_MODE="sync"

# ============================================
# STORAGE PROVIDER
# ============================================
# r2 or local
STORAGE_PROVIDER="r2"

# ============================================
# CLOUDFLARE R2 (S3-compatible)
# ============================================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="webcoinlabs-assets"
# You can keep the template placeholder; runtime resolves it using R2_ACCOUNT_ID.
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"

# ============================================
# LOCAL FILE STORAGE (fallback/dev only)
# ============================================
# Absolute path for server uploads (fallback if STORAGE_PROVIDER=local)
# Example (Windows): E:\\webcoinlabs\\.data
LOCAL_STORAGE_ROOT=""
# Public URL path served for local uploaded assets
PUBLIC_UPLOAD_ROOT="/uploads"

# ============================================
# SHARED RATE LIMITING (OPTIONAL - UPSTASH)
# ============================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================
# INTERNAL JOB DRAIN + REMINDERS
# ============================================
# Secret required by /api/internal/jobs/drain endpoint.
INTERNAL_JOBS_SECRET=""
# Optional reminder delivery webhook endpoint/token.
EVENT_REMINDER_WEBHOOK_URL=""
EVENT_REMINDER_WEBHOOK_TOKEN=""

# ============================================
# OBSERVABILITY SINK (OPTIONAL)
# ============================================
OBSERVABILITY_SINK_URL=""
OBSERVABILITY_SINK_TOKEN=""

# ============================================
# FOUNDER OS EXPANSION (REQUIRED IN PRODUCTION)
# ============================================
OPENCLAW_BASE_URL=""
OPENCLAW_API_KEY=""
APP_ENCRYPTION_SECRET=""
UPLOAD_SCAN_HOOK_URL=""
